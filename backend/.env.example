# Server
PORT=8888
NODE_ENV=production

# Database (Railway will automatically provide DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_study_buddy

# Redis (Railway will automatically provide REDIS_URL)
REDIS_URL=redis://localhost:6379

# Runs on a local OpenAI-compatible model (Ollama + Qwen).
# The API key is unused by Ollama but the SDK requires a non-empty value.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=qwen3:1.7b
OPENAI_MAX_TOKENS_PER_REQUEST=1000
OPENAI_TEMPERATURE=0.7

# Auth
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Token Limits (set DAILY_TOKEN_LIMIT=0 to disable token limits in production)
DAILY_TOKEN_LIMIT=10000
MAX_TOKENS_PER_REQUEST=500

# CORS Configuration (set to your frontend Railway URL)
FRONTEND_URL=https://your-frontend-url.railway.app